# ===========================================
# MEDIUM AUTO PUBLISHER — Environment Config
# ===========================================
# Copy this file to .env and fill in values

# --- App ---
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/medium_publisher?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- JWT Auth ---
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# --- AI Providers ---
# OpenAI (GPT-4o for fast tasks)
OPENAI_API_KEY=sk-...

# Anthropic (Claude Sonnet for blog writing — best quality)
ANTHROPIC_API_KEY=sk-ant-...

# Default AI provider: "openai" | "anthropic"
AI_PROVIDER=anthropic
AI_WRITING_MODEL=claude-sonnet-4-5
AI_FAST_MODEL=gpt-4o-mini

# --- Image Generation ---
# DALL-E 3 via OpenAI (same key as above)
IMAGE_GENERATION_PROVIDER=openai
DALLE_MODEL=dall-e-3

# --- Medium API (Official — No Bot Risk!) ---
# Get your token at: https://medium.com/me/settings > Integration tokens
MEDIUM_API_BASE_URL=https://api.medium.com/v1
MEDIUM_INTEGRATION_TOKEN=your_medium_integration_token

# --- Content Quality ---
# Blog is rejected if AI probability exceeds this threshold (0-100)
AI_DETECTION_THRESHOLD=60
# Min reading time in minutes
MIN_READ_TIME_MINUTES=5

# --- Queue Config ---
BULL_REDIS_URL="redis://localhost:6379"

# --- Encryption (for storing sensitive user data) ---
ENCRYPTION_KEY=32_character_random_key_here_xxxx
